@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard phòng ban</h1>
        <p class="page-subtitle">@ViewBag.DepartmentName</p>
    </div>
</div>

<div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px;margin-bottom:24px;">
    <div class="card"><div class="page-subtitle">Nhân viên phòng tôi</div><div class="page-title">@ViewBag.EmployeeCount</div></div>
    <div class="card"><div class="page-subtitle">Hồ sơ chờ duyệt</div><div class="page-title">@ViewBag.PendingCount</div></div>
    <div class="card"><div class="page-subtitle">Thông báo mới</div><div class="page-title">@ViewBag.NewAnnouncements</div></div>
</div>

<div class="data-table-wrapper">
    <table class="data-table">
        <thead><tr><th>Họ tên</th><th>Phòng ban</th><th>Chức vụ</th><th>Trạng thái</th></tr></thead>
        <tbody>
        @foreach (var item in ViewBag.DepartmentEmployees)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Department</td>
                <td>@item.Position</td>
                <td>@item.Status</td>
            </tr>
        }
        </tbody>
    </table>
</div>
