@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var d = ViewBag.Department;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Chỉnh sửa phòng ban</h1>
        <p class="page-subtitle">Cập nhật: @d.Name</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card" style="max-width: 600px;">
    <form asp-action="Edit" asp-route-id="@d.Id" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label">Tên phòng ban <span class="text-error">*</span></label>
            <input type="text" name="Name" class="form-control" value="@d.Name" required />
        </div>
        <div class="form-group">
            <label class="form-label">Mã phòng ban</label>
            <input type="text" name="Code" class="form-control" value="@d.Code" required />
        </div>
        <div class="form-group">
            <label class="form-label">Trưởng phòng</label>
            <select name="ManagerId" class="form-control">
                <option value="">-- Chọn trưởng phòng --</option>
                @foreach (var manager in ViewBag.Managers)
                {
                    <option value="@manager.Id" selected="@(manager.FullName == d.ManagerName)">@manager.FullName</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Mô tả</label>
            <textarea name="Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="d-flex gap-12" style="justify-content: flex-end; margin-top: 24px;">
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Cập nhật</button>
        </div>
    </form>
</div>
