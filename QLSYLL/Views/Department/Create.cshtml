@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Thêm phòng ban</h1>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card" style="max-width: 600px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label">Tên phòng ban <span class="text-error">*</span></label>
            <input type="text" name="Name" class="form-control" placeholder="VD: Phòng Kỹ thuật" required />
        </div>
        <div class="form-group">
            <label class="form-label">Mã phòng ban <span class="text-error">*</span></label>
            <input type="text" name="Code" class="form-control" placeholder="VD: KT" required maxlength="10" />
        </div>
        <div class="form-group">
            <label class="form-label">Trưởng phòng</label>
            <select name="ManagerId" class="form-control">
                <option value="">-- Chọn trưởng phòng --</option>
                @foreach (var manager in ViewBag.Managers)
                {
                    <option value="@manager.Id">@manager.FullName</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Mô tả</label>
            <textarea name="Description" class="form-control" rows="3" placeholder="Mô tả chức năng phòng ban"></textarea>
        </div>

        <div class="d-flex gap-12" style="justify-content: flex-end; margin-top: 24px;">
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Thêm</button>
        </div>
    </form>
</div>
