@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var u = ViewBag.UserItem;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Chỉnh sửa tài khoản</h1>
        <p class="page-subtitle">Cập nhật thông tin: @u.FullName</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card" style="max-width: 600px;">
    <form asp-action="Edit" asp-route-id="@u.Id" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label">Tên đăng nhập</label>
            <input type="text" class="form-control" value="@u.Username" disabled />
            <span class="form-hint">Tên đăng nhập không thể thay đổi</span>
        </div>
        <div class="form-group">
            <label class="form-label">Họ và tên <span class="text-error">*</span></label>
            <input type="text" name="FullName" class="form-control" value="@u.FullName" required />
        </div>
        <div class="form-group">
            <label class="form-label">Email <span class="text-error">*</span></label>
            <input type="email" name="Email" class="form-control" value="@u.Email" required />
        </div>
        <div class="form-group">
            <label class="form-label">Vai trò</label>
            <select name="Role" class="form-control">
                @foreach (var role in ViewBag.Roles)
                {
                    <option value="@role" selected="@(u.Role.Code == role)">@role</option>
                }
            </select>
        </div>

        <div class="d-flex gap-12" style="justify-content: flex-end; margin-top: 24px;">
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Cập nhật</button>
        </div>
    </form>
</div>
