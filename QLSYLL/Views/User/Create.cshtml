@model AdminAccountCreateViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Tạo tài khoản quản trị</h1>
        <p class="page-subtitle">Màn hình này chỉ dùng để tạo tài khoản nội bộ cho SA hoặc HR.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card" style="max-width: 600px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-error" style="margin-bottom: 16px;"></div>

        <div class="form-group">
            <label asp-for="Username" class="form-label">Tên đăng nhập <span class="text-error">*</span></label>
            <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập" />
            <span asp-validation-for="Username" class="text-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="FullName" class="form-label">Họ và tên <span class="text-error">*</span></label>
            <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
            <span asp-validation-for="FullName" class="text-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Email" class="form-label">Email <span class="text-error">*</span></label>
            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
            <span asp-validation-for="Email" class="text-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Password" class="form-label">Mật khẩu <span class="text-error">*</span></label>
            <input asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" />
            <span asp-validation-for="Password" class="text-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu <span class="text-error">*</span></label>
            <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" />
            <span asp-validation-for="ConfirmPassword" class="text-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Role" class="form-label">Vai trò</label>
            <select asp-for="Role" asp-items="ViewBag.Roles" class="form-control"></select>
            <span asp-validation-for="Role" class="text-error"></span>
            <span class="form-hint">Tài khoản Manager hoặc Employee phải được tạo cùng hồ sơ tại module Hồ sơ SYLL.</span>
        </div>

        <div class="d-flex gap-12" style="justify-content: flex-end; margin-top: 24px;">
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Tạo tài khoản</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
