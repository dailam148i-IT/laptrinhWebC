@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var a = ViewBag.Announcement;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Chỉnh sửa thông báo</h1>
        <p class="page-subtitle">@a.Title</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card" style="max-width: 800px;">
    <form asp-action="Edit" asp-route-id="@a.Id" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label">Tiêu đề <span class="text-error">*</span></label>
            <input type="text" name="Title" class="form-control" value="@a.Title" required />
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Mức độ ưu tiên</label>
                <select name="Priority" class="form-control">
                    <option value="Bình thường" selected="@(a.Priority == "Bình thường")">Bình thường</option>
                    <option value="Quan trọng" selected="@(a.Priority == "Quan trọng")">Quan trọng</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Trạng thái</label>
                <select name="Status" class="form-control">
                    <option value="Bản nháp" selected="@(a.Status == "Bản nháp")">Bản nháp</option>
                    <option value="Đã đăng" selected="@(a.Status == "Đã đăng")">Đã đăng</option>
                </select>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Nội dung</label>
            <textarea name="Content" class="form-control editor" rows="8">@(a.Content ?? $"Nội dung mẫu cho thông báo \"{a.Title}\"")</textarea>
        </div>

        <div class="d-flex gap-12" style="justify-content: flex-end; margin-top: 24px;">
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Cập nhật</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({ selector: '.editor', height: 260, menubar: false });
    </script>
}
