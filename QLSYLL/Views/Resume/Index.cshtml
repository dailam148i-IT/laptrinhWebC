@{
    ViewData["Title"] = "Hồ sơ sơ yếu lý lịch";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var canManageResumes = (bool)(ViewBag.CanManageResumes ?? false);
    var page = (int)(ViewBag.Page ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 5);
    var search = ViewBag.Search as string;
    int? selectedDepartmentId = ViewBag.SelectedDepartmentId is int departmentValue ? departmentValue : null;
    var selectedStatus = ViewBag.SelectedStatus as string;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Hồ sơ sơ yếu lý lịch</h1>
        <p class="page-subtitle">Quản lý danh sách hồ sơ nhân viên</p>
    </div>
    @if (canManageResumes)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Thêm hồ sơ
        </a>
    }
</div>

<div class="card mb-24">
    <form method="get" asp-action="Index" class="d-flex gap-16 align-center" style="flex-wrap: wrap;">
        <div class="input-icon-wrapper" style="flex: 1; min-width: 220px;">
            <i class="bi bi-search input-icon"></i>
            <input type="text" name="search" value="@search" class="form-control" placeholder="Tìm theo tên hoặc số điện thoại..." style="padding-left: 40px;" />
        </div>
        <select name="departmentId" class="form-control" style="width: 200px;">
            <option value="">-- Phòng ban --</option>
            @foreach (var department in ViewBag.Departments)
            {
                <option value="@department.Id" selected="@(selectedDepartmentId == department.Id)">@department.Name</option>
            }
        </select>
        <select name="status" class="form-control" style="width: 170px;">
            <option value="">-- Trạng thái --</option>
            <option value="Đã duyệt" selected="@(selectedStatus == "Đã duyệt")">Đã duyệt</option>
            <option value="Chờ duyệt" selected="@(selectedStatus == "Chờ duyệt")">Chờ duyệt</option>
            <option value="Bị khóa" selected="@(selectedStatus == "Bị khóa")">Bị khóa</option>
        </select>
        <button type="submit" class="btn btn-secondary btn-sm"><i class="bi bi-funnel"></i> Lọc</button>
        <a asp-action="Index" class="btn btn-ghost btn-sm">Xóa lọc</a>
        <div class="input-icon-wrapper" style="flex: 1; min-width: 240px;">
            <i class="bi bi-lightning input-icon"></i>
            <input type="text" class="form-control" placeholder="AJAX tìm theo kỹ năng..." id="skillSearchInput" style="padding-left: 40px;" />
        </div>
    </form>
    <div class="text-muted" style="margin-top:12px;">Tổng hồ sơ: @(ViewBag.TotalItems ?? 0)</div>
    <div id="skillSearchResults" class="text-muted" style="margin-top:12px;"></div>
</div>

<div class="data-table-wrapper">
    <table class="data-table">
        <thead>
            <tr>
                <th>STT</th>
                <th>Họ và tên</th>
                <th>Ngày sinh</th>
                <th>Giới tính</th>
                <th>Điện thoại</th>
                <th>Phòng ban</th>
                <th>Chức vụ</th>
                <th>Trạng thái</th>
                <th style="text-align: center;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @{ var stt = ((page - 1) * pageSize) + 1; }
            @foreach (var r in ViewBag.Resumes)
            {
                <tr>
                    <td>@(stt++)</td>
                    <td>
                        <div class="d-flex align-center gap-8">
                            <div class="avatar">@r.FullName.ToString().Substring(0, 1)</div>
                            <div>
                                <div style="font-weight: 500;">@r.FullName</div>
                                <div class="text-muted" style="font-size:0.857rem;">@r.EducationLevel</div>
                            </div>
                        </div>
                    </td>
                    <td>@r.BirthDate</td>
                    <td>@r.Gender</td>
                    <td>@r.Phone</td>
                    <td>@r.Department</td>
                    <td>@r.Position</td>
                    <td>
                        @{
                            string bc = "badge-success", bi = "bi-check-circle";
                            if (r.Status == "Chờ duyệt") { bc = "badge-warning"; bi = "bi-clock"; }
                            else if (r.Status == "Bị khóa") { bc = "badge-error"; bi = "bi-lock"; }
                        }
                        <span class="badge @bc"><i class="bi @bi" style="margin-right: 4px;"></i>@r.Status</span>
                    </td>
                    <td style="text-align: center;">
                        <div class="d-flex gap-8" style="justify-content: center;">
                            <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-ghost btn-sm" title="Xem chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (canManageResumes)
                            {
                                <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-ghost btn-sm" title="Chỉnh sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@r.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa hồ sơ này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-ghost btn-sm text-error" title="Xóa">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if ((int)(ViewBag.TotalPages ?? 1) > 1)
{
    <div class="d-flex gap-8" style="justify-content:flex-end;margin-top:16px;flex-wrap:wrap;">
        @for (var i = 1; i <= (int)ViewBag.TotalPages; i++)
        {
            <a asp-action="Index"
               asp-route-page="@i"
               asp-route-search="@search"
               asp-route-departmentId="@selectedDepartmentId"
               asp-route-status="@selectedStatus"
               class="btn @(i == page ? "btn-primary" : "btn-secondary") btn-sm">@i</a>
        }
    </div>
}

@section Scripts {
    <script>
        const skillInput = document.getElementById('skillSearchInput');
        const skillResults = document.getElementById('skillSearchResults');

        skillInput?.addEventListener('input', async function () {
            const term = this.value.trim();
            if (term.length < 2) {
                skillResults.innerHTML = '';
                return;
            }

            const response = await fetch(`/Resume/SearchBySkill?term=${encodeURIComponent(term)}`);
            const data = await response.json();
            skillResults.innerHTML = data.length
                ? data.map(x => `<div>${x.fullName} - ${x.skill}</div>`).join('')
                : '<div>Không tìm thấy kết quả</div>';
        });
    </script>
}
