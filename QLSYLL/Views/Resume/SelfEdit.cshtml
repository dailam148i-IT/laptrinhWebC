@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var resume = ViewBag.Resume;
    var education = ViewBag.PrimaryEducation;
    var skillsText = ViewBag.SkillsText as string ?? "";
    var documents = resume.EmployeeDocuments;
    var hasAvatar = !string.IsNullOrWhiteSpace((string?)resume.AvatarPath);
}

<div class="page-header">
    <div>
        <h1 class="page-title">Hồ sơ cá nhân</h1>
        <p class="page-subtitle">Chỉ chỉnh sửa các trường được phép</p>
    </div>
</div>

<div class="card">
    <div style="display:flex;justify-content:center;margin-bottom:24px;">
        <div style="width:180px;padding:20px;border:1px dashed var(--hairline);border-radius:20px;background:var(--surface);text-align:center;">
            <img id="avatarPreview"
                 src="@(hasAvatar ? resume.AvatarPath : "")"
                 alt="@resume.FullName"
                 style="width:112px;height:112px;border-radius:50%;object-fit:cover;display:@(hasAvatar ? "block" : "none");margin:0 auto 12px;" />

            <div id="avatarPlaceholder"
                 class="avatar avatar-lg"
                 style="width:112px;height:112px;font-size:2rem;margin:0 auto 12px;display:@(hasAvatar ? "none" : "flex");">
                @resume.FullName.ToString().Substring(0, 1)
            </div>

            <div style="font-weight:600;">Ảnh đại diện</div>
            <div class="text-muted" style="font-size:0.857rem;margin-top:4px;">JPG/PNG tối đa 2MB</div>
        </div>
    </div>

    <form asp-action="SelfEdit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="form-group" style="margin-bottom:16px;">
            <label class="form-label">Ảnh đại diện</label>
            <input type="file"
                   id="avatarFileInput"
                   name="avatarFile"
                   class="form-control"
                   accept=".jpg,.jpeg,.png"
                   oninput="previewAvatar(this)" />
            <div class="form-hint">Chỉ preview, sẽ lưu khi bấm “Lưu thay đổi”.</div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="form-group">
                <label class="form-label">Họ và tên</label>
                <input class="form-control" value="@resume.FullName" disabled />
            </div>
            <div class="form-group">
                <label class="form-label">Phòng ban</label>
                <input class="form-control" value="@resume.Department.Name" disabled />
            </div>
            <div class="form-group">
                <label class="form-label">Số điện thoại</label>
                <input name="Phone" class="form-control" value="@resume.Phone" />
            </div>
            <div class="form-group">
                <label class="form-label">Email cá nhân</label>
                <input name="PersonalEmail" class="form-control" value="@resume.PersonalEmail" />
            </div>
            <div class="form-group" style="grid-column:1/-1;">
                <label class="form-label">Chỗ ở hiện tại</label>
                <input name="CurrentAddress" class="form-control" value="@resume.CurrentAddress" />
            </div>
            <div class="form-group">
                <label class="form-label">Trình độ phổ thông</label>
                <input name="GeneralEducationLevel" class="form-control" value="@education?.GeneralEducationLevel" />
            </div>
            <div class="form-group">
                <label class="form-label">Trình độ</label>
                <input name="EducationLevel" class="form-control" value="@education?.EducationLevel" />
            </div>
            <div class="form-group">
                <label class="form-label">Chuyên ngành</label>
                <input name="Major" class="form-control" value="@education?.Major" />
            </div>
            <div class="form-group">
                <label class="form-label">Trường đào tạo</label>
                <input name="SchoolName" class="form-control" value="@education?.SchoolName" />
            </div>
            <div class="form-group">
                <label class="form-label">Năm tốt nghiệp</label>
                <input name="GraduationYear" class="form-control" value="@education?.GraduationYear" />
            </div>
            <div class="form-group">
                <label class="form-label">Xếp loại</label>
                <input name="Ranking" class="form-control" value="@education?.Ranking" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngoại ngữ</label>
                <input name="ForeignLanguage" class="form-control" value="@education?.ForeignLanguage" />
            </div>
            <div class="form-group">
                <label class="form-label">Tin học</label>
                <input name="ITLevel" class="form-control" value="@education?.ITLevel" />
            </div>
            <div class="form-group" style="grid-column:1/-1;">
                <label class="form-label">Kỹ năng</label>
                <textarea name="Skills" class="form-control editor" rows="4">@skillsText</textarea>
            </div>
        </div>
        <div class="d-flex gap-12" style="justify-content:flex-end;margin-top:24px;">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Lưu thay đổi</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({ selector: '.editor', height: 180, menubar: false });

        function previewAvatar(input) {
            var preview = document.getElementById('avatarPreview');
            var placeholder = document.getElementById('avatarPlaceholder');
            var file = input.files && input.files[0];
            if (!file || !preview) return;

            var url = URL.createObjectURL(file);
            preview.src = url;
            preview.style.display = 'block';
            if (placeholder) placeholder.style.display = 'none';
        }
    </script>
}
