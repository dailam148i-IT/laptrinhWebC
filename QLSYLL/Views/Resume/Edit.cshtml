@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var r = ViewBag.Resume;
    var education = r.Education;
    var skillsText = ViewBag.SkillsText as string ?? "";
    var documents = r.Documents;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Chỉnh sửa hồ sơ</h1>
        <p class="page-subtitle">Cập nhật thông tin: @r.FullName</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card mb-24">
    <h2 class="card-title"><i class="bi bi-image" style="margin-right: 8px;"></i>Ảnh nhân viên</h2>
    <div style="display:flex;justify-content:center;margin-bottom:24px;">
        <div style="width:180px;padding:20px;border:1px dashed var(--hairline);border-radius:20px;background:var(--surface);text-align:center;">
            <img id="avatarPreview"
                 data-original="@(!string.IsNullOrWhiteSpace((string?)r.AvatarPath) ? r.AvatarPath : "")"
                 src="@(!string.IsNullOrWhiteSpace((string?)r.AvatarPath) ? r.AvatarPath : "")"
                 alt="@r.FullName"
                 style="width:112px;height:112px;border-radius:50%;object-fit:cover;display:@(!string.IsNullOrWhiteSpace((string?)r.AvatarPath) ? "block" : "none");margin:0 auto 12px;" />
            <div id="avatarFallback"
                 class="avatar avatar-lg"
                 style="width:112px;height:112px;font-size:2rem;margin:0 auto 12px;display:@(string.IsNullOrWhiteSpace((string?)r.AvatarPath) ? "flex" : "none");">
                @r.FullName.ToString().Substring(0, 1)
            </div>
            <div style="font-weight:600;">Ảnh nhân viên</div>
            <div class="text-muted" style="font-size:0.857rem;margin-top:4px;">HR/Admin có thể cập nhật trực tiếp</div>
        </div>
    </div>
    <div class="d-flex gap-12 align-center" style="margin-bottom:24px;">
        <input id="avatarInput" form="editForm" type="file" name="avatarFile" class="form-control" accept=".jpg,.jpeg,.png" />
        <button id="avatarClearBtn" type="button" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle"></i> Bỏ chọn ảnh
        </button>
    </div>
</div>

<form id="editForm" asp-action="Edit" asp-route-id="@r.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" id="clearAvatarFlag" name="ClearAvatar" value="false" />
    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-person-badge" style="margin-right: 8px;"></i>Thông tin cá nhân</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Họ và tên <span class="text-error">*</span></label>
                <input type="text" name="FullName" class="form-control" value="@r.FullName" required />
            </div>
            <div class="form-group">
                <label class="form-label">Tên gọi khác</label>
                <input type="text" name="AliasName" class="form-control" value="@r.AliasName" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngày sinh <span class="text-error">*</span></label>
                <input type="date" name="BirthDate" class="form-control" value="@r.BirthDate" required />
            </div>
            <div class="form-group">
                <label class="form-label">Giới tính</label>
                <select name="Gender" class="form-control">
                    <option value="Nam" selected="@(r.Gender == "Nam")">Nam</option>
                    <option value="Nữ" selected="@(r.Gender == "Nữ")">Nữ</option>
                    <option value="Khác" selected="@(r.Gender == "Khác")">Khác</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Số điện thoại</label>
                <input type="tel" name="Phone" class="form-control" value="@r.Phone" />
            </div>
            <div class="form-group">
                <label class="form-label">Nơi sinh</label>
                <input type="text" name="BirthPlace" class="form-control" value="@r.BirthPlace" />
            </div>
            <div class="form-group">
                <label class="form-label">Quê quán</label>
                <input type="text" name="Hometown" class="form-control" value="@r.Hometown" />
            </div>
            <div class="form-group">
                <label class="form-label">Email cá nhân</label>
                <input type="email" name="PersonalEmail" class="form-control" value="@r.PersonalEmail" />
            </div>
            <div class="form-group">
                <label class="form-label">Email công ty</label>
                <input type="email" name="CompanyEmail" class="form-control" value="@r.CompanyEmail" />
            </div>
            <div class="form-group">
                <label class="form-label">Tình trạng hôn nhân</label>
                <input type="text" name="MaritalStatus" class="form-control" value="@r.MaritalStatus" />
            </div>
            <div class="form-group">
                <label class="form-label">Dân tộc</label>
                <input type="text" name="Ethnicity" class="form-control" value="@r.Ethnicity" />
            </div>
            <div class="form-group">
                <label class="form-label">Tôn giáo</label>
                <input type="text" name="Religion" class="form-control" value="@r.Religion" />
            </div>
            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">Hộ khẩu thường trú</label>
                <input type="text" name="PermanentAddress" class="form-control" value="@r.PermanentAddress" />
            </div>
            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">Chỗ ở hiện tại</label>
                <input type="text" name="CurrentAddress" class="form-control" value="@r.CurrentAddress" />
            </div>
        </div>
    </div>

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-shield-check" style="margin-right: 8px;"></i>Pháp lý và phúc lợi</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">CCCD / CMND</label>
                <input type="text" name="IdentityNumber" class="form-control" value="@r.IdentityNumber" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngày cấp</label>
                <input type="date" name="IdentityIssuedDate" class="form-control" value="@r.IdentityIssuedDate" />
            </div>
            <div class="form-group">
                <label class="form-label">Nơi cấp</label>
                <input type="text" name="IdentityIssuedPlace" class="form-control" value="@r.IdentityIssuedPlace" />
            </div>
            <div class="form-group">
                <label class="form-label">Mã số thuế</label>
                <input type="text" name="TaxCode" class="form-control" value="@r.TaxCode" />
            </div>
            <div class="form-group">
                <label class="form-label">Sổ BHXH</label>
                <input type="text" name="SocialInsuranceNumber" class="form-control" value="@r.SocialInsuranceNumber" />
            </div>
            <div class="form-group">
                <label class="form-label">Số tài khoản</label>
                <input type="text" name="BankAccountNumber" class="form-control" value="@r.BankAccountNumber" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngân hàng</label>
                <input type="text" name="BankName" class="form-control" value="@r.BankName" />
            </div>
            <div class="form-group">
                <label class="form-label">Chi nhánh</label>
                <input type="text" name="BankBranch" class="form-control" value="@r.BankBranch" />
            </div>
        </div>
    </div>

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-briefcase" style="margin-right: 8px;"></i>Thông tin công việc</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Phòng ban</label>
                <select name="DepartmentId" class="form-control">
                    @foreach (var department in ViewBag.Departments)
                    {
                        <option value="@department.Id" selected="@(department.Id == r.DepartmentId)">@department.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Chức vụ</label>
                <select name="PositionId" class="form-control">
                    @foreach (var position in ViewBag.Positions)
                    {
                        <option value="@position.Id" selected="@(position.Id == r.PositionId)">@position.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Ngày vào làm</label>
                <input type="date" name="JoinDate" class="form-control" value="@r.JoinDate" />
            </div>
        </div>
    </div>

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-mortarboard" style="margin-right: 8px;"></i>Học vấn và kỹ năng</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Trình độ phổ thông</label>
                <input type="text" name="GeneralEducationLevel" class="form-control" value="@education?.GeneralEducationLevel" />
            </div>
            <div class="form-group">
                <label class="form-label">Trình độ chuyên môn</label>
                <input type="text" name="EducationLevel" class="form-control" value="@education?.EducationLevel" />
            </div>
            <div class="form-group">
                <label class="form-label">Trường đào tạo</label>
                <input type="text" name="SchoolName" class="form-control" value="@education?.SchoolName" />
            </div>
            <div class="form-group">
                <label class="form-label">Chuyên ngành</label>
                <input type="text" name="Major" class="form-control" value="@education?.Major" />
            </div>
            <div class="form-group">
                <label class="form-label">Năm tốt nghiệp</label>
                <input type="number" name="GraduationYear" class="form-control" value="@education?.GraduationYear" />
            </div>
            <div class="form-group">
                <label class="form-label">Xếp loại</label>
                <input type="text" name="Ranking" class="form-control" value="@education?.Ranking" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngoại ngữ</label>
                <input type="text" name="ForeignLanguage" class="form-control" value="@education?.ForeignLanguage" />
            </div>
            <div class="form-group">
                <label class="form-label">Tin học</label>
                <input type="text" name="ITLevel" class="form-control" value="@education?.ITLevel" />
            </div>
            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">Kỹ năng</label>
                <textarea name="Skills" class="form-control" rows="3">@skillsText</textarea>
            </div>
        </div>
    </div>

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-building" style="margin-right: 8px;"></i>Thông tin Đoàn / Đảng</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Ngày vào Đoàn</label>
                <input type="date" name="YouthUnionJoinDate" class="form-control" value="@r.YouthUnionJoinDate" />
            </div>
            <div class="form-group">
                <label class="form-label">Nơi kết nạp Đoàn</label>
                <input type="text" name="YouthUnionJoinPlace" class="form-control" value="@r.YouthUnionJoinPlace" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngày vào Đảng</label>
                <input type="date" name="CommunistPartyJoinDate" class="form-control" value="@r.CommunistPartyJoinDate" />
            </div>
            <div class="form-group">
                <label class="form-label">Nơi kết nạp Đảng</label>
                <input type="text" name="CommunistPartyJoinPlace" class="form-control" value="@r.CommunistPartyJoinPlace" />
            </div>
            <div class="form-group">
                <label class="form-label">Trạng thái Đảng</label>
                <input type="text" name="CommunistPartyStatus" class="form-control" value="@r.CommunistPartyStatus" />
            </div>
        </div>
    </div>

    <div class="d-flex gap-12" style="justify-content: flex-end; margin-bottom: 24px;">
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Cập nhật</button>
    </div>
</form>

<div class="card mb-24">
    <h2 class="card-title"><i class="bi bi-paperclip" style="margin-right: 8px;"></i>Tài liệu hồ sơ</h2>
    <form asp-action="UploadDocument" method="post" enctype="multipart/form-data" style="margin-bottom:20px;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="employeeId" value="@r.Id" />
        <input type="hidden" name="returnAction" value="Edit" />
        <div style="display:grid;grid-template-columns:1fr 180px 1fr auto;gap:12px;align-items:end;">
            <div class="form-group">
                <label class="form-label">Tên tài liệu</label>
                <input type="text" name="title" class="form-control" placeholder="CV, SYLL, CCCD scan..." />
            </div>
            <div class="form-group">
                <label class="form-label">Loại</label>
                <select name="category" class="form-control">
                    <option value="CV">CV</option>
                    <option value="SYLL">SYLL</option>
                    <option value="HopDong">Hợp đồng</option>
                    <option value="Khac">Khác</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Tệp đính kèm</label>
                <input type="file" name="documentFile" class="form-control" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" required />
            </div>
            <button type="submit" class="btn btn-secondary"><i class="bi bi-upload"></i> Tải lên</button>
        </div>
    </form>

    @if (documents.Count > 0)
    {
        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr><th>Tên</th><th>Loại</th><th>Tệp</th><th>Ngày tải</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var item in documents)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Category</td>
                        <td><a href="@item.FilePath" target="_blank">@item.FileName</a></td>
                        <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td style="text-align:right;">
                            <form asp-action="DeleteDocument" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="returnAction" value="Edit" />
                                <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i> Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">Chưa có tài liệu đính kèm.</p>
    }
</div>

<script>
    (function () {
        const input = document.getElementById("avatarInput");
        const preview = document.getElementById("avatarPreview");
        const fallback = document.getElementById("avatarFallback");
        const clearBtn = document.getElementById("avatarClearBtn");
        const clearFlag = document.getElementById("clearAvatarFlag");

        if (!input || !preview || !fallback || !clearBtn || !clearFlag) return;

        const originalSrc = preview.getAttribute("data-original") || "";

        function showEmptyPreview() {
            preview.src = "";
            preview.style.display = "none";
            fallback.style.display = "flex";
        }

        function showOriginalPreview() {
            if (originalSrc.trim().length > 0) {
                preview.src = originalSrc;
                preview.style.display = "block";
                fallback.style.display = "none";
            } else {
                showEmptyPreview();
            }
        }

        input.addEventListener("change", function () {
            const file = this.files && this.files[0];
            if (!file) {
                clearFlag.value = "false";
                showOriginalPreview();
                return;
            }

            clearFlag.value = "false";
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.style.display = "block";
                fallback.style.display = "none";
            };
            reader.readAsDataURL(file);
        });

        clearBtn.addEventListener("click", function () {
            input.value = "";
            clearFlag.value = "true";
            showEmptyPreview();
        });
    })();
</script>
