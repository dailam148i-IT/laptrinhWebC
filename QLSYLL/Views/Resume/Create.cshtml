@{
    ViewData["Title"] = "Thêm hồ sơ mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Thêm hồ sơ mới</h1>
        <p class="page-subtitle">Điền đầy đủ thông tin sơ yếu lý lịch và khởi tạo tài khoản đăng nhập cho nhân viên.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-person-lock" style="margin-right: 8px;"></i>Thông tin tài khoản</h2>
        <p class="form-hint" style="margin-bottom: 16px;">
            Tạo hồ sơ này sẽ đồng thời tạo tài khoản đăng nhập cho nhân viên. Tài khoản quản trị SA/HR không tạo tại đây.
        </p>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Username <span class="text-error">*</span></label>
                <input type="text" name="Username" class="form-control" placeholder="nhanvien01" required />
            </div>
            <div class="form-group">
                <label class="form-label">Email tài khoản <span class="text-error">*</span></label>
                <input type="email" name="AccountEmail" class="form-control" placeholder="ten@congty.vn" required />
            </div>
            <div class="form-group">
                <label class="form-label">Mật khẩu <span class="text-error">*</span></label>
                <input type="password" name="Password" class="form-control" minlength="6" required />
            </div>
            <div class="form-group">
                <label class="form-label">Xác nhận mật khẩu <span class="text-error">*</span></label>
                <input type="password" name="ConfirmPassword" class="form-control" minlength="6" required />
            </div>
            <div class="form-group d-flex align-items-center" style="gap: 8px; grid-column: 1 / -1;">
                <input type="checkbox" id="IsManager" name="IsManager" value="true" />
                <label class="form-label" for="IsManager">Là quản lý (gán role Manager và phòng ban)</label>
            </div>
        </div>
    </div>

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-person-badge" style="margin-right: 8px;"></i>Thông tin cá nhân</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Họ và tên <span class="text-error">*</span></label>
                <input type="text" name="FullName" class="form-control" placeholder="Nhập họ và tên" required />
            </div>
            <div class="form-group">
                <label class="form-label">Tên gọi khác</label>
                <input type="text" name="AliasName" class="form-control" placeholder="Bí danh / tên gọi khác" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngày sinh <span class="text-error">*</span></label>
                <input type="date" name="BirthDate" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">Giới tính</label>
                <select name="Gender" class="form-control">
                    <option value="Nam">Nam</option>
                    <option value="Nữ">Nữ</option>
                    <option value="Khác">Khác</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Số điện thoại</label>
                <input type="tel" name="Phone" class="form-control" placeholder="0901234567" />
            </div>
            <div class="form-group">
                <label class="form-label">Email cá nhân</label>
                <input type="email" name="PersonalEmail" class="form-control" placeholder="example@email.com" />
            </div>
            <div class="form-group">
                <label class="form-label">Email công ty</label>
                <input type="email" name="CompanyEmail" class="form-control" placeholder="ten@congty.vn" />
            </div>
            <div class="form-group">
                <label class="form-label">CCCD / CMND</label>
                <input type="text" name="IdentityNumber" class="form-control" placeholder="Nhập số CCCD" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngày cấp CCCD</label>
                <input type="date" name="IdentityIssuedDate" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Nơi cấp CCCD</label>
                <input type="text" name="IdentityIssuedPlace" class="form-control" placeholder="Cơ quan cấp" />
            </div>
            <div class="form-group">
                <label class="form-label">Nơi sinh</label>
                <input type="text" name="BirthPlace" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Quê quán</label>
                <input type="text" name="Hometown" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Tình trạng hôn nhân</label>
                <input type="text" name="MaritalStatus" class="form-control" placeholder="Độc thân / Đã kết hôn / Khác" />
            </div>
            <div class="form-group">
                <label class="form-label">Dân tộc</label>
                <input type="text" name="Ethnicity" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Tôn giáo</label>
                <input type="text" name="Religion" class="form-control" />
            </div>
            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">Hộ khẩu thường trú</label>
                <input type="text" name="PermanentAddress" class="form-control" placeholder="Địa chỉ trên sổ hộ khẩu / CCCD" />
            </div>
            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">Chỗ ở hiện tại</label>
                <input type="text" name="CurrentAddress" class="form-control" placeholder="Địa chỉ đang sinh sống" />
            </div>
        </div>
    </div>

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-shield-check" style="margin-right: 8px;"></i>Pháp lý và phúc lợi</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Mã số thuế cá nhân</label>
                <input type="text" name="TaxCode" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Số sổ BHXH</label>
                <input type="text" name="SocialInsuranceNumber" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Số tài khoản ngân hàng</label>
                <input type="text" name="BankAccountNumber" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Tên ngân hàng</label>
                <input type="text" name="BankName" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Chi nhánh</label>
                <input type="text" name="BankBranch" class="form-control" />
            </div>
        </div>
    </div>

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-briefcase" style="margin-right: 8px;"></i>Thông tin công việc</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Phòng ban</label>
                <select name="DepartmentId" class="form-control">
                    <option value="">-- Chọn phòng ban --</option>
                    @foreach (var department in ViewBag.Departments)
                    {
                        <option value="@department.Id">@department.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Chức vụ</label>
                <select name="PositionId" class="form-control">
                    <option value="">-- Chọn chức vụ --</option>
                    @foreach (var position in ViewBag.Positions)
                    {
                        <option value="@position.Id">@position.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Ngày vào làm</label>
                <input type="date" name="JoinDate" class="form-control" />
            </div>
        </div>
    </div>

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-mortarboard" style="margin-right: 8px;"></i>Trình độ học vấn</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Trình độ phổ thông</label>
                <input type="text" name="GeneralEducationLevel" class="form-control" placeholder="Ví dụ: 12/12" />
            </div>
            <div class="form-group">
                <label class="form-label">Trình độ chuyên môn</label>
                <select name="EducationLevel" class="form-control">
                    <option>Đại học</option>
                    <option>Cao đẳng</option>
                    <option>Trung cấp</option>
                    <option>Thạc sĩ</option>
                    <option>Tiến sĩ</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Trường / Cơ sở đào tạo</label>
                <input type="text" name="SchoolName" class="form-control" placeholder="Tên trường" />
            </div>
            <div class="form-group">
                <label class="form-label">Chuyên ngành</label>
                <input type="text" name="Major" class="form-control" placeholder="Chuyên ngành đào tạo" />
            </div>
            <div class="form-group">
                <label class="form-label">Năm tốt nghiệp</label>
                <input type="number" name="GraduationYear" class="form-control" placeholder="2020" />
            </div>
            <div class="form-group">
                <label class="form-label">Xếp loại</label>
                <input type="text" name="Ranking" class="form-control" placeholder="Giỏi / Khá / Trung bình" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngoại ngữ</label>
                <input type="text" name="ForeignLanguage" class="form-control" placeholder="IELTS 6.5, N3..." />
            </div>
            <div class="form-group">
                <label class="form-label">Tin học</label>
                <input type="text" name="ITLevel" class="form-control" placeholder="MOS, Văn phòng..." />
            </div>
            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">Kỹ năng</label>
                <input type="text" name="Skills" class="form-control" placeholder="VD: C#, SQL Server, Giao tiếp" />
            </div>
        </div>
    </div>

    <div class="card mb-24">
        <h2 class="card-title"><i class="bi bi-building" style="margin-right: 8px;"></i>Thông tin Đoàn / Đảng</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label">Ngày kết nạp Đoàn</label>
                <input type="date" name="YouthUnionJoinDate" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Nơi kết nạp Đoàn</label>
                <input type="text" name="YouthUnionJoinPlace" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Ngày kết nạp Đảng</label>
                <input type="date" name="CommunistPartyJoinDate" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Nơi kết nạp Đảng</label>
                <input type="text" name="CommunistPartyJoinPlace" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Trạng thái Đảng</label>
                <input type="text" name="CommunistPartyStatus" class="form-control" placeholder="Dự bị / Chính thức" />
            </div>
        </div>
    </div>

    <div class="d-flex gap-12" style="justify-content: flex-end;">
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg"></i> Lưu hồ sơ
        </button>
    </div>
</form>
