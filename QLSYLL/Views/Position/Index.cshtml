@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Quản lý chức vụ</h1>
        <p class="page-subtitle">Danh sách chức vụ trong công ty</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm chức vụ</a>
</div>

<div class="data-table-wrapper">
    <table class="data-table">
        <thead>
            <tr>
                <th>STT</th>
                <th>Tên chức vụ</th>
                <th>Cấp bậc</th>
                <th>Lương cơ bản</th>
                <th>Số nhân viên</th>
                <th>Mô tả</th>
                <th style="text-align: center;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @{ int stt = 1; }
            @foreach (var p in ViewBag.Positions)
            {
                <tr>
                    <td>@(stt++)</td>
                    <td style="font-weight: 500;">@p.Name</td>
                    <td><span class="badge badge-primary">Cấp @p.Level</span></td>
                    <td>@p.BaseSalary</td>
                    <td><span class="badge badge-info">@p.EmployeeCount người</span></td>
                    <td class="text-muted">@p.Description</td>
                    <td style="text-align: center;">
                        <div class="d-flex gap-8" style="justify-content: center;">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-ghost btn-sm" title="Sửa"><i class="bi bi-pencil-square"></i></a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline;"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa chức vụ này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-ghost btn-sm text-error" title="Xóa"><i class="bi bi-trash3"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
