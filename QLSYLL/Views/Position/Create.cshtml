@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div><h1 class="page-title">Thêm chức vụ</h1></div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card" style="max-width: 600px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label class="form-label">Tên chức vụ <span class="text-error">*</span></label>
            <input type="text" name="Name" class="form-control" placeholder="VD: Chuyên viên" required />
        </div>
        <div class="form-group">
            <label class="form-label">Cấp bậc <span class="text-error">*</span></label>
            <input type="number" name="Level" class="form-control" placeholder="1-10" min="1" max="10" required />
        </div>
        <div class="form-group">
            <label class="form-label">Lương cơ bản</label>
            <input type="text" name="BaseSalary" class="form-control" placeholder="VD: 15,000,000 ₫" />
        </div>
        <div class="form-group">
            <label class="form-label">Mô tả</label>
            <textarea name="Description" class="form-control" rows="3" placeholder="Mô tả vai trò chức vụ"></textarea>
        </div>
        <div class="d-flex gap-12" style="justify-content: flex-end; margin-top: 24px;">
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Thêm</button>
        </div>
    </form>
</div>
