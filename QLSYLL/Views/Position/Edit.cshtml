@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var p = ViewBag.Position;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Chỉnh sửa chức vụ</h1>
        <p class="page-subtitle">Cập nhật: @p.Name</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card" style="max-width: 600px;">
    <form asp-action="Edit" asp-route-id="@p.Id" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label class="form-label">Tên chức vụ <span class="text-error">*</span></label>
            <input type="text" name="Name" class="form-control" value="@p.Name" required />
        </div>
        <div class="form-group">
            <label class="form-label">Cấp bậc</label>
            <input type="number" name="Level" class="form-control" value="@p.Level" />
        </div>
        <div class="form-group">
            <label class="form-label">Lương cơ bản</label>
            <input type="text" name="BaseSalary" class="form-control" value="@p.BaseSalary" />
        </div>
        <div class="form-group">
            <label class="form-label">Mô tả</label>
            <textarea name="Description" class="form-control" rows="3">@p.Description</textarea>
        </div>
        <div class="d-flex gap-12" style="justify-content: flex-end; margin-top: 24px;">
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Cập nhật</button>
        </div>
    </form>
</div>
