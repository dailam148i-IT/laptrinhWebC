@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Audit Log</h1>
        <p class="page-subtitle">Lịch sử thao tác hệ thống</p>
    </div>
</div>

<div class="data-table-wrapper">
    <table class="data-table">
        <thead><tr><th>Thời gian</th><th>Người dùng</th><th>Bảng</th><th>Record</th><th>Action</th><th>IP</th></tr></thead>
        <tbody>
        @foreach (var log in ViewBag.Logs)
        {
            <tr>
                <td>@log.Timestamp</td>
                <td>@log.UserName</td>
                <td>@log.TableName</td>
                <td>@log.RecordId</td>
                <td>@log.Action</td>
                <td>@log.IpAddress</td>
            </tr>
        }
        </tbody>
    </table>
</div>
