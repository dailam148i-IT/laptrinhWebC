@model QLSYLL.Models.ViewModels.ChangePasswordViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Đổi mật khẩu</h1>
        <p class="page-subtitle">Thay đổi mật khẩu đăng nhập của bạn</p>
    </div>
</div>

<div class="card" style="max-width: 500px;">
    <div style="text-align: center; margin-bottom: 24px;">
        <div class="avatar avatar-lg" style="margin: 0 auto 12px; background: var(--primary-light); color: var(--primary);">
            <i class="bi bi-shield-lock" style="font-size: 2rem;"></i>
        </div>
        <p class="text-muted">Mật khẩu mới phải có ít nhất 6 ký tự</p>
    </div>

    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="CurrentPassword" class="form-label"></label>
            <div class="input-icon-wrapper">
                <i class="bi bi-lock input-icon"></i>
                <input asp-for="CurrentPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại" />
            </div>
            <span asp-validation-for="CurrentPassword" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="NewPassword" class="form-label"></label>
            <div class="input-icon-wrapper">
                <i class="bi bi-key input-icon"></i>
                <input asp-for="NewPassword" class="form-control" placeholder="Nhập mật khẩu mới" />
            </div>
            <span asp-validation-for="NewPassword" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <div class="input-icon-wrapper">
                <i class="bi bi-key input-icon"></i>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" />
            </div>
            <span asp-validation-for="ConfirmPassword" class="form-error"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-block mt-24">
            <i class="bi bi-check-lg"></i> Đổi mật khẩu
        </button>
    </form>
</div>
