@* Trang Đăng nhập — sử dụng Bootstrap Icons *@
@model QLSYLL.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-logo">
        <div class="logo-icon">5</div>
        <div class="logo-text">
            QLSYLL
            <span>Hệ thống quản lý sơ yếu lý lịch</span>
        </div>
    </div>

    <h1 class="auth-title">Đăng nhập</h1>
    <p class="auth-subtitle">Nhập thông tin tài khoản để truy cập hệ thống</p>

    @await Html.PartialAsync("_Notification")

    @if (ViewData.ModelState.ContainsKey("") && ViewData.ModelState[""]!.Errors.Count > 0)
    {
        <div class="alert alert-error">
            <i class="bi bi-x-circle-fill"></i>
            <span>@ViewData.ModelState[""]!.Errors[0].ErrorMessage</span>
        </div>
    }

    @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { id = "loginForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="form-group">
            @Html.LabelFor(m => m.Username, new { @class = "form-label" })
            <div class="input-icon-wrapper">
                <i class="bi bi-person input-icon"></i>
                @Html.TextBoxFor(m => m.Username, new
                {
                    @class = "form-control" + (ViewData.ModelState["Username"]?.Errors.Count > 0 ? " is-invalid" : ""),
                    placeholder = "Nhập tên đăng nhập",
                    autofocus = "autofocus",
                    id = "input-username"
                })
            </div>
            @Html.ValidationMessageFor(m => m.Username, "", new { @class = "form-error" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Password, new { @class = "form-label" })
            <div class="input-icon-wrapper">
                <i class="bi bi-lock input-icon"></i>
                @Html.PasswordFor(m => m.Password, new
                {
                    @class = "form-control" + (ViewData.ModelState["Password"]?.Errors.Count > 0 ? " is-invalid" : ""),
                    placeholder = "Nhập mật khẩu",
                    id = "input-password"
                })
                <button type="button" class="password-toggle" onclick="togglePassword()" title="Hiện/ẩn mật khẩu">
                    <i class="bi bi-eye" id="toggleIcon"></i>
                </button>
            </div>
            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "form-error" })
        </div>

        <div class="d-flex justify-between align-center mb-24">
            <div class="form-check">
                @Html.CheckBoxFor(m => m.RememberMe, new { id = "input-remember" })
                @Html.LabelFor(m => m.RememberMe, new { @for = "input-remember" })
            </div>
            <a asp-action="ForgotPassword" asp-controller="Account" style="font-size: 0.929rem;">
                Quên mật khẩu?
            </a>
        </div>

        <button type="submit" class="btn btn-primary btn-block btn-lg" id="btn-login">
            <i class="bi bi-box-arrow-in-right"></i>
            Đăng nhập
        </button>
    }

    <div class="auth-footer">
        &copy; @DateTime.Now.Year Hệ thống QLSYLL — Five Member
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword() {
            var input = document.getElementById('input-password');
            var icon = document.getElementById('toggleIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}
