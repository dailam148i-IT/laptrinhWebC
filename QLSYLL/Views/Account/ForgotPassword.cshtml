@* Trang Quên mật khẩu — sử dụng Bootstrap Icons *@
@model QLSYLL.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-logo">
        <div class="logo-icon">5</div>
        <div class="logo-text">
            QLSYLL
            <span>Hệ thống quản lý sơ yếu lý lịch</span>
        </div>
    </div>

    <h1 class="auth-title">Quên mật khẩu</h1>
    <p class="auth-subtitle">Nhập tên đăng nhập và email đã đăng ký để nhận mật khẩu mới</p>

    <form asp-action="ForgotPassword" asp-controller="Account" method="post" id="forgotPasswordForm">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Username" class="form-label"></label>
            <div class="input-icon-wrapper">
                <i class="bi bi-person input-icon"></i>
                <input asp-for="Username"
                       class="form-control"
                       placeholder="Nhập tên đăng nhập"
                       autofocus
                       id="input-username" />
            </div>
            <span asp-validation-for="Username" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email" class="form-label"></label>
            <div class="input-icon-wrapper">
                <i class="bi bi-envelope input-icon"></i>
                <input asp-for="Email"
                       class="form-control"
                       placeholder="Nhập email đã đăng ký"
                       id="input-email" />
            </div>
            <span asp-validation-for="Email" class="form-error"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-block btn-lg mt-8" id="btn-reset">
            <i class="bi bi-send"></i>
            Gửi yêu cầu
        </button>
    </form>

    <div class="auth-divider">hoặc</div>

    <div style="text-align: center;">
        <a asp-action="Login" asp-controller="Account" class="btn btn-secondary btn-block">
            <i class="bi bi-arrow-left"></i>
            Quay lại trang đăng nhập
        </a>
    </div>

    <div class="auth-footer">
        &copy; @DateTime.Now.Year Hệ thống QLSYLL — Five Member
    </div>
</div>
